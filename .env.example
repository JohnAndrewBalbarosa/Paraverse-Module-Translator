# Required
CURRICULUM_URL=https://paraverse.feutech.edu.ph/network-map/curriculum/

# Optional: if your school has a specific curriculum query ID, place it here.
# Example: CS
CURRICULUM_CODE=

# Optional defaults for runtime prompt (you can leave these blank).
TARGET_LANGUAGE=
TRANSLATION_STYLE=

# Translation provider settings
# Leave blank to skip translation and only scrape/export HTML.
RESEARCH_PROVIDER=gemini
RESEARCH_MODEL=gemma-4-31b-it
RESEARCH_API_KEY=your-api-key-here
# Optional for OpenAI-compatible providers.
# For Gemini OpenAI-compatible endpoint, use:
# RESEARCH_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
RESEARCH_BASE_URL=

# Legacy OpenAI fallback (still supported by code):
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Regular or irregular handling mode
STUDENT_MODE=regular

# Playwright browser behavior
HEADLESS=false
